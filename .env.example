# App configuration
# For Vercel: set this to your deployment URL, e.g. https://hostingwiththelocals.vercel.app
# Locally: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Connection mode: 'local' for self-hosted/LAN, 'cloud' for PartyKit cloud
NEXT_PUBLIC_MODE=local

# Public PartyKit host for browser websocket connections
# For Vercel: set NEXT_PUBLIC_PARTYKIT_HOST to your deployed PartyKit host
# (e.g. my-party.username.partykit.dev) and PARTYKIT_SERVER_URL to match.
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999

# Server-side PartyKit base URL used by API routes
PARTYKIT_SERVER_URL=http://127.0.0.1:1999

# (Optional) Cloud Storage for Vercel deployments
# If provided, PDFs will be uploaded to Vercel Blob instead of local memory.
BLOB_READ_WRITE_TOKEN=
