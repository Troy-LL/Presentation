{
  "name": "interactive-presentation",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,party \"npm run dev --workspace @interactive-presentation/web\" \"npm run dev:party --workspace @interactive-presentation/web\"",
    "local": "node scripts/start-local.mjs",
    "build": "npm run build --workspace @interactive-presentation/web",
    "start": "npm run start --workspace @interactive-presentation/web",
    "start:prod": "npm run start --workspace @interactive-presentation/web",
    "lint": "npm run lint --workspace @interactive-presentation/web",
    "typecheck": "npm run typecheck --workspace @interactive-presentation/web",
    "test": "npm run test --workspace @interactive-presentation/web"
  },
  "devDependencies": {
    "chalk": "^5.6.2",
    "concurrently": "^9.1.2"
  }
}
